# ==============================================================================
# MinIO Stack — Environment Variables
# ==============================================================================

# --- Credentials -------------------------------------------------------------
# Change these in production! These are the root admin credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Ports (local access without Traefik) ------------------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Traefik hostnames (only needed with proxy template) ---------------------
# MINIO_API_HOST=s3.example.com
# MINIO_CONSOLE_HOST=minio.example.com

# --- Resources ----------------------------------------------------------------
MINIO_MEM_LIMIT=1g
MINIO_CPUS=1.0
