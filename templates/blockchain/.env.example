# ==============================================================================
# Blockchain Stack — Environment Variables
# ==============================================================================

# --- Geth --------------------------------------------------------------------
# Block period in seconds. 0 = mine only when transactions are pending.
# Set to e.g. 5 to mine a block every 5 seconds regardless of transactions.
GETH_BLOCK_PERIOD=0

# --- Ports (local access without Traefik) ------------------------------------
GETH_RPC_PORT=8545
GETH_WS_PORT=8546
EXPLORER_PORT=4000
FRONTEND_PORT=3000

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_PASSWORD=blockscout

# --- Blockscout --------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY_BASE=super_secret_key_base_that_should_be_at_least_64_bytes_long_for_production

# --- Traefik hostnames (only needed with proxy template) ---------------------
# GETH_RPC_HOST=rpc.example.com
# EXPLORER_HOST=explorer.example.com

# --- RPC Protection (applied via Traefik middlewares) ------------------------
# Rate limiting: requests per second per client IP
RPC_RATE_LIMIT_AVG=20
RPC_RATE_LIMIT_BURST=50
#
# IP whitelist: comma-separated CIDRs allowed to reach the RPC
# 0.0.0.0/0 = allow all (default). Restrict for production:
# RPC_ALLOWED_IPS=203.0.113.10/32,198.51.100.0/24
RPC_ALLOWED_IPS=0.0.0.0/0

# ==============================================================================
# Whitelabel — Blockscout Frontend Customization
# ==============================================================================
# Docs: https://github.com/blockscout/frontend/blob/main/docs/ENVS.md

# --- Network Identity --------------------------------------------------------
NEXT_PUBLIC_NETWORK_NAME=Dev Chain
NEXT_PUBLIC_NETWORK_SHORT_NAME=DEV
NEXT_PUBLIC_NETWORK_ID=1337
NEXT_PUBLIC_IS_TESTNET=true
NEXT_PUBLIC_NETWORK_CURRENCY_NAME=Ether
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL=ETH
NEXT_PUBLIC_NETWORK_CURRENCY_DECIMALS=18

# --- Logo & Favicon ----------------------------------------------------------
# Main logo in navbar (recommended: 240x40 SVG/PNG)
# NEXT_PUBLIC_NETWORK_LOGO=https://example.com/logo.svg
# NEXT_PUBLIC_NETWORK_LOGO_DARK=https://example.com/logo-dark.svg
#
# Collapsed sidebar icon (recommended: 60x60 SVG/PNG)
# NEXT_PUBLIC_NETWORK_ICON=https://example.com/icon.svg
# NEXT_PUBLIC_NETWORK_ICON_DARK=https://example.com/icon-dark.svg
#
# Browser tab favicon (recommended: 180x180 PNG)
# FAVICON_MASTER_URL=https://example.com/favicon.png

# --- Colors & Theme ----------------------------------------------------------
# Default theme: "light" | "midnight" | "dark"
# NEXT_PUBLIC_COLOR_THEME_DEFAULT=light
#
# Override color tokens (JSON). Example — custom primary accent:
# NEXT_PUBLIC_COLOR_THEME_OVERRIDES={"button":{"filled":{"background":{"_light":{"value":"#1a73e8"},"_dark":{"value":"#4da3ff"}}}}}

# --- Typography --------------------------------------------------------------
# Custom fonts (must support weights 400, 500, 600, 700)
# NEXT_PUBLIC_FONT_FAMILY_HEADING={"name":"Montserrat","url":"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700"}
# NEXT_PUBLIC_FONT_FAMILY_BODY={"name":"Inter","url":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700"}

# --- Homepage Hero Banner ----------------------------------------------------
# Customize the hero section with text, background color/gradient, and text color
# NEXT_PUBLIC_HOMEPAGE_HERO_BANNER_CONFIG={"text":"My Private Chain Explorer","background":["linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%)"],"text_color":["#ffffff"]}

# --- OG / SEO ----------------------------------------------------------------
# Social sharing preview (recommended: 1200x600, max 8MB)
# NEXT_PUBLIC_OG_IMAGE_URL=https://example.com/og-image.png
# NEXT_PUBLIC_OG_DESCRIPTION=Block explorer for My Private Chain
#
# Remove "Blockscout" from page titles
NEXT_PUBLIC_PROMOTE_BLOCKSCOUT_IN_TITLE=false

# --- Footer Links -------------------------------------------------------------
# Custom footer link groups (JSON array)
# NEXT_PUBLIC_FOOTER_LINKS=[{"title":"Company","links":[{"text":"About","url":"https://example.com/about"},{"text":"Docs","url":"https://example.com/docs"}]}]

# --- Navigation ---------------------------------------------------------------
# Extra links in the nav menu
# NEXT_PUBLIC_OTHER_LINKS=[{"url":"https://example.com","text":"Main Site"}]
#
# Layout: "vertical" (sidebar) | "horizontal" (top bar)
# NEXT_PUBLIC_NAVIGATION_LAYOUT=vertical
