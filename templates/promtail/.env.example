# ==============================================================================
# Promtail Stack — Environment Variables
# ==============================================================================

# --- Host label -----------------------------------------------------------
# Identifies this host in Grafana (Labels panel). Use descriptive names
# like "core", "apps", "prod-db", etc.
HOST_LABEL=unknown

# --- Loki destination ------------------------------------------------------
# Colocated Loki: http://loki:3100/loki/api/v1/push
# Remote Loki:    https://loki.example.com/loki/api/v1/push
LOKI_URL=http://loki:3100/loki/api/v1/push

# --- Basic auth (only for remote Loki over HTTPS) --------------------------
LOKI_USERNAME=
LOKI_PASSWORD=

# --- Resources ----------------------------------------------------------------
PROMTAIL_MEM_LIMIT=128m
PROMTAIL_CPUS=0.25
