# ==============================================================================
# PostgreSQL Stack — Environment Variables
# ==============================================================================

# --- Image --------------------------------------------------------------------
# Default: postgres:16-alpine
# Use pgvector/pgvector:pg16 for vector search
# Use postgis/postgis:16-3.4-alpine for spatial queries
POSTGRES_IMAGE=postgres:16-alpine

# --- Credentials -------------------------------------------------------------
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Port (local access) -----------------------------------------------------
POSTGRES_PORT=5432

# --- Resources ----------------------------------------------------------------
POSTGRES_MEM_LIMIT=512m
POSTGRES_CPUS=1.0
