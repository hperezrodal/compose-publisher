# Grafana
GRAFANA_HOST=grafana.example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Prometheus
PROMETHEUS_HOST=prometheus.example.com
PROMETHEUS_RETENTION=15d

# Basic auth for Prometheus UI (htpasswd format)
# Generate: htpasswd -nb admin password | sed 's/\$/\$\$/g'
MONITORING_BASIC_AUTH=admin:$$2y$$05$$changeme

# App targets (comma-separated host:port for Prometheus to scrape)
APP_TARGETS=app:8080
