# ==============================================================================
# Redis Stack — Environment Variables
# ==============================================================================

# --- Credentials -------------------------------------------------------------
REDIS_PASSWORD=redis

# --- Port (local access) -----------------------------------------------------
REDIS_PORT=6379

# --- Memory -------------------------------------------------------------------
# Max memory Redis can use. When reached, evicts keys per maxmemory-policy.
REDIS_MAXMEMORY=256mb

# --- Resources ----------------------------------------------------------------
REDIS_MEM_LIMIT=512m
REDIS_CPUS=0.5
