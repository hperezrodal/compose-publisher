# ==============================================================================
# IPFS Stack — Environment Variables
# ==============================================================================

# --- IPFS Profile -------------------------------------------------------------
# "server" — headless, no local discovery (recommended for VPS)
# "lowpower" — reduced resource usage
# "flatfs" — use flatfs datastore (better for large files)
IPFS_PROFILE=server

# --- Ports --------------------------------------------------------------------
IPFS_SWARM_PORT=4001
IPFS_API_PORT=5001
IPFS_GATEWAY_PORT=8080

# --- Swarm binding ------------------------------------------------------------
# 0.0.0.0 = public P2P (connect to IPFS network)
# 127.0.0.1 = private node (no P2P, local only)
IPFS_SWARM_ADDR=0.0.0.0

# --- Resources ----------------------------------------------------------------
IPFS_MEM_LIMIT=2g
IPFS_CPUS=2.0

# --- Traefik hostnames (only needed with proxy template) ---------------------
# IPFS_GATEWAY_HOST=ipfs.example.com
